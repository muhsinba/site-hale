# Copy to /etc/sitehale.env on the VM and fill in real values.
# `chmod 600 /etc/sitehale.env && chown sitehale:sitehale /etc/sitehale.env`

NODE_ENV=production
PORT=3000

# Prisma + SQLite. Absolute file: URL pointing at the persistent boot disk.
# The booking form writes here, so the file (and its directory) must be
# writable by the `sitehale` user — see ReadWritePaths in sitehale.service.
DATABASE_URL="file:/var/lib/sitehale/prod.db"
